    <script>
        // State Management
        const TOTAL_CARDS = 112;
        const STORAGE_KEY = 'scenecard_project_data';
        const AUTOSAVE_DELAY = 2000;
        let cards = {};
        let activeCard = 1;
        let autoSaveTimeout = null;
        let lastSaveTime = null;
        let undoStack = [];
        let redoStack = [];
        const MAX_UNDO = 50;

        const SHOT_PRESETS = [
            'WIDE', 'MEDIUM', 'CLOSE-UP', 'CU', '2-SHOT', 'OTS', 
            'POV', 'INSERT', 'ESTABLISHING', 'TRACKING', 'CRANE', 
            'DOLLY', 'HANDHELD', 'MASTER', 'EXTREME CLOSE-UP', 'ECU',
            'MEDIUM CLOSE-UP', 'MCU', 'AMERICAN SHOT', 'OVERHEAD', 'LOW ANGLE', 'HIGH ANGLE'
        ];

        // Initialize
        function init() {
            if (!loadFromLocalStorage()) {
                initEmptyCards();
                initSampleCard();
            }
            initShotPresets();
            initTabs();
            initRichEditor();
            renderMatrix();
            loadCard(activeCard);
            updateCardCount();
            updateSaveStatus();
            saveUndoState();
        }

        function initEmptyCards() {
            for (let i = 1; i <= TOTAL_CARDS; i++) {
                cards[i] = createEmptyCard();
            }
        }

        function createEmptyCard() {
            return {
                sceneTitle: '',
                actHeader: '',
                titleProject: '',
                type: '',
                dateField: '',
                storyMap: '',
                clip: '',
                mp3: '',
                intExtLocation: '',
                locationDetail: '',
                timeOfDay: '',
                inPoint: '',
                beat1: '',
                beat2: '',
                turn: '',
                outPoint: '',
                emo: '',
                shot: '',
                sounds: '',
                visualEfx: '',
                soundFxs: '',
                mp3fx: '',
                syfy: '',
                characters: {
                    c1: { active: false, name: '' },
                    c2: { active: false, name: '' },
                    c3: { active: false, name: '' },
                    c4: { active: false, name: '' }
                },
                memory: '',
                shotsA: [],
                shotsB: [],
                shotsC: [],
                shotsD: [],
                shotsE: [],
                shotsF: [],
                priceRate: 0,
                priceTotal: 0,
                lineItems: [],
                status: 'draft',
                callbacks: []
            };
        }

        function initSampleCard() {
            cards[50] = createEmptyCard();
            cards[50].sceneTitle = 'WAREHOUSE CHASE SEQUENCE';
            cards[50].actHeader = '050/112 Act 2 Pg 15/track1/videoclip1';
            cards[50].titleProject = '##title/project/ NEON CITY BLUES';
            cards[50].type = '##type/ Thriller';
            cards[50].dateField = '2024-10-15';
            cards[50].storyMap = 'MS: Scene 12 - Tech Noir Chase /pg15/act2';
            cards[50].clip = '#12 = 45';
            cards[50].mp3 = '#8 = 35';
            cards[50].intExtLocation = 'EXT: ABANDONED WAREHOUSE - NIGHT';
            cards[50].locationDetail = 'Rooftop and fire escape';
            cards[50].timeOfDay = 'NIGHT';
            cards[50].inPoint = 'JACK sprints through broken doorway, blood on shirt';
            cards[50].beat1 = 'Gunshots ring out behind him. He ducks behind crate.';
            cards[50].beat2 = 'CHASE lights up the space with muzzle flash. "Give up!"';
            cards[50].turn = 'JACK spots the fire escape. One chance to live.';
            cards[50].outPoint = 'Jack vaults over railing into darkness below.';
            cards[50].emo = '[Desperate] → [Determined]';
            cards[50].shot = 'Handheld, Wide tracking shot, CU on blood, POV escape';
            cards[50].sounds = 'Rain on metal roof, distant sirens, industrial hum';
            cards[50].visualEfx = 'Muzzle flashes, sparks, blood splatter, rain streaks';
            cards[50].soundFxs = 'Gunshots echo, metal impacts, heavy breathing';
            cards[50].mp3fx = 'bullets ricochet / metal bang / human grunts';
            cards[50].syfy = 'neural implant HUD flickers / tracking virus active';
            cards[50].characters = {
                c1: { active: true, name: 'JACK' },
                c2: { active: true, name: 'CHASE' },
                c3: { active: false, name: '' },
                c4: { active: false, name: '' }
            };
            cards[50].memory = '<p><strong>Callback:</strong> Jack shot in Act 1.</p><p><strong>Payoff:</strong> Virus mentioned in Scene 3 now active.</p>';
            cards[50].shotsA = [
                { id: 1, description: 'Jack running - handheld tracking', lens: '35mm', duration: '00:15', notes: 'Lead shot' },
                { id: 2, description: 'Wide warehouse establish', lens: '18mm', duration: '00:08', notes: 'Crane up' }
            ];
            cards[50].shotsB = [
                { id: 3, description: 'CU blood on shirt', lens: '85mm', duration: '00:03', notes: 'Insert' }
            ];
            cards[50].priceRate = 150.00;
            cards[50].priceTotal = 150.00;
            cards[50].lineItems = [
                { account: '3001', description: 'Location Rental', quantity: 1, rate: 2500.00, total: 2500.00 },
                { account: '4501', description: 'Practical SFX', quantity: 1, rate: 800.00, total: 800.00 },
                { account: '5101', description: 'Stunt Coordinator', quantity: 1, rate: 1200.00, total: 1200.00 }
            ];
            cards[50].status = 'revised';
            activeCard = 50;
        }

        function saveUndoState() {
            undoStack.push(JSON.stringify(cards[activeCard]));
            if (undoStack.length > MAX_UNDO) undoStack.shift();
            redoStack = [];
        }

        function undo() {
            if (undoStack.length > 1) {
                redoStack.push(undoStack.pop());
                cards[activeCard] = JSON.parse(undoStack[undoStack.length - 1]);
                loadCard(activeCard);
                showToast('Undo', 'Previous state restored');
            }
        }

        function redo() {
            if (redoStack.length > 0) {
                const state = redoStack.pop();
                cards[activeCard] = JSON.parse(state);
                undoStack.push(state);
                loadCard(activeCard);
                showToast('Redo', 'Change restored');
            }
        }

        document.getElementById('undoBtn').addEventListener('click', undo);
        document.getElementById('redoBtn').addEventListener('click', redo);

        function saveToLocalStorage() {
            try {
                const projectData = {
                    cards: cards,
                    activeCard: activeCard,
                    lastSaved: new Date().toISOString(),
                    version: '2.3'
                };
                localStorage.setItem(STORAGE_KEY, JSON.stringify(projectData));
                lastSaveTime = new Date();
                updateSaveStatus(true);
                return true;
            } catch (e) {
                console.error('Failed to save to localStorage:', e);
                showToast('Save Failed', 'Browser storage full or disabled', true);
                return false;
            }
        }

        function loadFromLocalStorage() {
            try {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) {
                    const projectData = JSON.parse(saved);
                    cards = projectData.cards;
                    // Migrate old cards to new structure
                    Object.keys(cards).forEach(key => {
                        if (!cards[key].lineItems) cards[key].lineItems = [];
                        if (!cards[key].shotsA) cards[key].shotsA = [];
                        if (!cards[key].shotsB) cards[key].shotsB = [];
                        if (!cards[key].shotsC) cards[key].shotsC = [];
                        if (!cards[key].shotsD) cards[key].shotsD = [];
                        if (!cards[key].shotsE) cards[key].shotsE = [];
                        if (!cards[key].shotsF) cards[key].shotsF = [];
                        if (!cards[key].status) cards[key].status = 'draft';
                        if (!cards[key].callbacks) cards[key].callbacks = [];
                        if (!cards[key].locationDetail) cards[key].locationDetail = '';
                        if (!cards[key].timeOfDay) cards[key].timeOfDay = '';
                    });
                    activeCard = projectData.activeCard || 1;
                    lastSaveTime = projectData.lastSaved ? new Date(projectData.lastSaved) : null;
                    return true;
                }
            } catch (e) {
                console.error('Failed to load from localStorage:', e);
            }
            return false;
        }

        function clearLocalStorage() {
            localStorage.removeItem(STORAGE_KEY);
            lastSaveTime = null;
            updateSaveStatus();
        }

        function autoSaveData() {
            clearTimeout(autoSaveTimeout);
            autoSaveTimeout = setTimeout(() => {
                saveToLocalStorage();
            }, AUTOSAVE_DELAY);
        }

        function updateSaveStatus(saved = false) {
            const statusEl = document.getElementById('saveStatus');
            const textEl = document.getElementById('saveStatusText');
            
            if (saved && lastSaveTime) {
                statusEl.classList.add('saved');
                textEl.textContent = `Last saved: ${lastSaveTime.toLocaleTimeString()}`;
            } else if (lastSaveTime) {
                statusEl.classList.add('saved');
                textEl.textContent = `Last saved: ${lastSaveTime.toLocaleTimeString()}`;
            } else {
                statusEl.classList.remove('saved');
                textEl.textContent = 'Not saved';
            }
        }

        function initTabs() {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabName = btn.dataset.tab;
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                    btn.classList.add('active');
                    document.querySelector(`.tab-content[data-tab-content="${tabName}"]`).classList.add('active');
                    
                    if (tabName === 'preview') {
                        updatePreviews();
                    }
                });
            });
        }

        function initShotPresets() {
            const container = document.getElementById('shotPresets');
            SHOT_PRESETS.forEach(preset => {
                const item = document.createElement('div');
                item.className = 'shot-preset-item';
                item.textContent = preset;
                item.addEventListener('click', () => {
                    const shotInput = document.getElementById('shot');
                    const currentValue = shotInput.value.trim();
                    if (currentValue && !currentValue.endsWith(',')) {
                        shotInput.value = currentValue + ', ' + preset;
                    } else if (currentValue) {
                        shotInput.value = currentValue + ' ' + preset;
                    } else {
                        shotInput.value = preset;
                    }
                    container.classList.remove('show');
                    saveCardData();
                    autoSaveData();
                });
                container.appendChild(item);
            });

            document.getElementById('shotPresetBtn').addEventListener('click', (e) => {
                e.stopPropagation();
                container.classList.toggle('show');
            });

            document.addEventListener('click', () => {
                container.classList.remove('show');
            });
        }

        function initRichEditor() {
            const editor = document.getElementById('memoryEditor');
            const hidden = document.getElementById('memory');

            document.getElementById('boldBtn').addEventListener('click', () => document.execCommand('bold'));
            document.getElementById('italicBtn').addEventListener('click', () => document.execCommand('italic'));
            document.getElementById('underlineBtn').addEventListener('click', () => document.execCommand('underline'));
            document.getElementById('bulletBtn').addEventListener('click', () => document.execCommand('insertUnorderedList'));
            document.getElementById('numberBtn').addEventListener('click', () => document.execCommand('insertOrderedList'));
            document.getElementById('addTimestampBtn').addEventListener('click', () => {
                const time = new Date().toLocaleTimeString();
                document.execCommand('insertText', false, `[${time}] `);
            });
            document.getElementById('addCallbackBtn').addEventListener('click', () => {
                const ref = prompt('Enter card reference (e.g., Card #025):');
                if (ref) {
                    cards[activeCard].callbacks.push(ref);
                    document.execCommand('insertHTML', false, `<span style="background: #fef3c7; padding: 1px 4px; border-radius: 2px;">[CALLBACK: ${ref}]</span> `);
                }
            });

            editor.addEventListener('input', () => {
                hidden.value = editor.innerHTML;
                saveCardData();
                autoSaveData();
            });
        }

        function renderMatrix() {
            const matrix = document.getElementById('cardMatrix');
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            matrix.innerHTML = '';
            
            for (let i = 1; i <= TOTAL_CARDS; i++) {
                const card = cards[i];
                const matchesSearch = !searchTerm || 
                    card.sceneTitle.toLowerCase().includes(searchTerm) ||
                    Object.values(card.characters).some(c => c.name.toLowerCase().includes(searchTerm)) ||
                    card.intExtLocation.toLowerCase().includes(searchTerm);

                if (!matchesSearch) continue;

                const btn = document.createElement('button');
                btn.className = 'card-stack-btn';
                btn.dataset.cardNum = i;
                btn.setAttribute('aria-label', `Card ${i}: ${card.sceneTitle || 'Empty'}`);
                
                const isFilled = isCardFilled(i);
                if (isFilled) btn.classList.add('filled');
                else btn.classList.add('empty');
                
                if (card.status) btn.classList.add(card.status);
                if (i === activeCard) btn.classList.add('active');

                const displayTitle = card.sceneTitle ? card.sceneTitle.substring(0, 12) : 'Empty';
                const fullTitle = card.sceneTitle || 'Untitled Scene';

                btn.innerHTML = `
                    <div class="font-typewriter text-[9px] font-bold text-amber-900">#${String(i).padStart(3, '0')}</div>
                    <div class="text-[7px] text-blue-800 truncate">${displayTitle}</div>
                `;
                btn.title = `#${String(i).padStart(3, '0')} - ${fullTitle} [${card.status.toUpperCase()}]`;
                
                btn.addEventListener('click', () => {
                    saveUndoState();
                    loadCard(i);
                });
                matrix.appendChild(btn);
            }
        }

        function isCardFilled(cardNum) {
            const card = cards[cardNum];
            return card.sceneTitle || card.actHeader || card.titleProject || card.inPoint || 
                   card.lineItems.length > 0 || card.memory || card.shotsA.length > 0;
        }

        function loadCard(num) {
            activeCard = num;
            const card = cards[num];
            
            document.getElementById('cardNumber').textContent = String(num).padStart(3, '0');
            document.getElementById('sceneTitle').value = card.sceneTitle || '';
            document.getElementById('actHeader').value = card.actHeader || '';
            document.getElementById('titleProject').value = card.titleProject || '';
            document.getElementById('type').value = card.type || '';
            document.getElementById('dateField').value = card.dateField || '';
            document.getElementById('storyMap').value = card.storyMap || '';
            document.getElementById('clip').value = card.clip || '';
            document.getElementById('mp3').value = card.mp3 || '';
            document.getElementById('intExtLocation').value = card.intExtLocation || '';
            document.getElementById('locationDetail').value = card.locationDetail || '';
            document.getElementById('timeOfDay').value = card.timeOfDay || '';
            document.getElementById('inPoint').value = card.inPoint || '';
            document.getElementById('beat1').value = card.beat1 || '';
            document.getElementById('beat2').value = card.beat2 || '';
            document.getElementById('turn').value = card.turn || '';
            document.getElementById('outPoint').value = card.outPoint || '';
            document.getElementById('emo').value = card.emo || '';
            document.getElementById('shot').value = card.shot || '';
            document.getElementById('sounds').value = card.sounds || '';
            document.getElementById('visualEfx').value = card.visualEfx || '';
            document.getElementById('soundFxs').value = card.soundFxs || '';
            document.getElementById('mp3fx').value = card.mp3fx || '';
            document.getElementById('syfy').value = card.syfy || '';
            document.getElementById('memory').value = card.memory || '';
            document.getElementById('memoryEditor').innerHTML = card.memory || '';
            document.getElementById('priceRate').value = card.priceRate || 0;
            document.getElementById('priceTotal').value = card.priceTotal || 0;
            document.getElementById('cardStatus').value = card.status || 'draft';
            document.getElementById('cardStatus').className = `status-tag ${card.status || 'draft'}`;

            updateCharCounts();

            ['c1', 'c2', 'c3', 'c4'].forEach(char => {
                const charData = card.characters[char];
                const block = document.querySelector(`.character-block[data-char="${char}"]`);
                const checkbox = block.querySelector('input[type="checkbox"]');
                const nameInput = block.querySelector('input[data-char-name]');
                
                checkbox.checked = charData.active;
                nameInput.value = charData.name || '';
                
                if (charData.active) block.classList.add('active');
                else block.classList.remove('active');
            });

            renderLineItems();
            renderShotTables();
            updateMirror();
            updatePreviews();
            renderMatrix();
            updateCardCount();
            updateTotalShots();
        }

        function updateCharCounts() {
            const fields = ['sceneTitle', 'inPoint', 'beat1', 'beat2', 'turn', 'outPoint'];
            fields.forEach(field => {
                const input = document.getElementById(field);
                const count = document.getElementById(field + 'Count');
                if (input && count) {
                    const len = input.value.length;
                    const max = input.maxLength || 100;
                    count.textContent = `${len}/${max}`;
                    if (len > max * 0.9) count.classList.add('over');
                    else count.classList.remove('over');
                }
            });
        }

        function saveCardData() {
            const card = cards[activeCard];
            card.sceneTitle = document.getElementById('sceneTitle').value;
            card.actHeader = document.getElementById('actHeader').value;
            card.titleProject = document.getElementById('titleProject').value;
            card.type = document.getElementById('type').value;
