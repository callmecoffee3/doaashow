        // Snapshot/ Canvas Rendering Functions
        function drawIndexCardToCanvas() {
            const canvas = document.getElementById('snapshotCanvas');
            const card = cards[activeCard];
            const width = 1600;
            const height = 2400;
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext('2d');

            // Background - aged paper texture
            const bgGradient = ctx.createLinearGradient(0, 0, 0, height);
            bgGradient.addColorStop(0, '#fffdf7');
            bgGradient.addColorStop(1, '#f7f3e8');
            ctx.fillStyle = bgGradient;
            ctx.fillRect(0, 0, width, height);

            // Add paper texture noise
            ctx.globalAlpha = 0.03;
            for (let i = 0; i < 5000; i++) {
                ctx.fillStyle = Math.random() > 0.5 ? '#c9b8a0' : '#8b6f47';
                ctx.fillRect(Math.random() * width, Math.random() * height, 1, 1);
            }
            ctx.globalAlpha = 1;

            // Ruled lines
            ctx.strokeStyle = 'rgba(201, 184, 160, 0.35)';
            ctx.lineWidth = 2;
            for (let y = 60; y < height; y += 50) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(width, y);
                ctx.stroke();
            }

            // Red margin line
            ctx.strokeStyle = 'rgba(153, 27, 0.5)';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(80, 0);
            ctx.lineTo(80, height);
            ctx.stroke();

            // Header border
            ctx.strokeStyle = '#991b1b';
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(0, 120);
            ctx.lineTo(width, 120);
            ctx.stroke();

            // Card ID and Status
            ctx.font = 'bold 36px "Special Elite", monospace';
            ctx.fillStyle = '#991b1b';
            ctx.fillText(`SCENE CARD #${String(activeCard).padStart(3, '0')}`, 100, 80);

            // Status badge
            const statusColors = {
                draft: { bg: '#fef3c7', text: '#92400e', border: '#f59e0b' },
                revised: { bg: '#dbeafe', text: '#1e40af', border: '#3b82f6' },
                locked: { bg: '#fee2e2', text: '#991b1b', border: '#ef4444' },
                shot: { bg: '#dcfce7', text: '#166534', border: '#22c55e' }
            };
            const statusColor = statusColors[card.status] || statusColors.draft;
            ctx.fillStyle = statusColor.bg;
            ctx.strokeStyle = statusColor.border;
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.roundRect(500, 50, 200, 50, 25);
            ctx.fill();
            ctx.stroke();
            ctx.font = 'bold 24px "Special Elite", monospace';
            ctx.fillStyle = statusColor.text;
            ctx.fillText(card.status.toUpperCase(), 570, 85);

            // Timestamp watermark
            const timestamp = new Date().toLocaleString();
            ctx.font = '20px "Kalam", cursive';
            ctx.fillStyle = 'rgba(121, 85, 72, 0.4)';
            ctx.save();
            ctx.translate(width - 100, height - 100);
            ctx.rotate(-Math.PI / 6);
            ctx.fillText(`Generated: ${timestamp}`, 0, 0);
            ctx.restore();

            // Main content
            let y = 180;
            const lineHeight = 50;
            const leftMargin = 100;
            const rightMargin = width - 100;
            const maxWidth = rightMargin - leftMargin;

            ctx.font = '28px "Special Elite", monospace';
            ctx.fillStyle = '#1e3a8a';

            const drawField = (label, value, isBold = false, color = '#1e3a8a') => {
                if (y > height - 100) return;
                ctx.font = (isBold ? 'bold ' : '') + '28px "Special Elite", monospace';
                ctx.fillStyle = '#991b1b';
                ctx.fillText(label, leftMargin, y);
                ctx.fillStyle = color;
                const valueY = y + lineHeight;
                wrapText(ctx, value || '', leftMargin, valueY, maxWidth, lineHeight);
                y += lineHeight * 3;
            };

            if (card.sceneTitle) {
                ctx.font = 'bold 42px "Special Elite", monospace';
                ctx.fillStyle = '#1e3a8a';
                wrapText(ctx, card.sceneTitle, leftMargin, y, maxWidth, 55);
                y += 80;
            }

            drawField('Act/Header:', card.actHeader);
            drawField('Project:', card.titleProject);
            drawField('Type:', card.type);
            drawField('Date:', card.dateField);
            drawField('Story Map:', card.storyMap);
            drawField('Clip:', card.clip);
            drawField('MP3:', card.mp3);
            drawField('INT/EXT:', card.intExtLocation, true);
            drawField('Location:', card.locationDetail);
            drawField('Time:', card.timeOfDay);
            drawField('IN:', card.inPoint);
            drawField('Beat 1:', card.beat1);
            drawField('Beat 2:', card.beat2);
            drawField('Turn:', card.turn);
            drawField('OUT:', card.outPoint);
            drawField('Emotion:', card.emo);
            drawField('Shot:', card.shot);
            drawField('Sounds:', card.sounds);
            drawField('Visual FX:', card.visualEfx);
            drawField('Sound FX:', card.soundFxs);
            drawField('MP3 FX:', card.mp3fx);
            drawField('Sci-Fi:', card.syfy);

            // Characters
            const activeChars = [];
            ['c1', 'c2', 'c3', 'c4'].forEach(c => {
                if (card.characters[c].active) {
                    activeChars.push(card.characters[c].name || c.toUpperCase());
                }
            });
            if (activeChars.length > 0) {
                drawField('Characters:', activeChars.join(', '));
            }

            return canvas;
        }

        function wrapText(ctx, text, x, y, maxWidth, lineHeight) {
            const words = text.split(' ');
            let line = '';
            let currentY = y;

            for (let n = 0; n < words.length; n++) {
                const testLine = line + words[n] + ' ';
                const metrics = ctx.measureText(testLine);
                const testWidth = metrics.width;
                if (testWidth > maxWidth && n > 0) {
                    ctx.fillText(line, x, currentY);
                    line = words[n] + ' ';
                    currentY += lineHeight;
                } else {
                    line = testLine;
                }
            }
            ctx.fillText(line, x, currentY);
        }

