            });
            
            if (format === 'fdx') {
                return generateFDXFormat(card);
            }
            
            let output = '';
            if (card.sceneTitle) {
                output += `SCENE TITLE: ${card.sceneTitle}\n`;
                output += `${'═'.repeat(60)}\n`;
            }
            output += `${card.actHeader || '###/### Act # Pg ##/track1/videoclip1'}\n`;
            output += `${card.titleProject || '##title/project/'}\n`;
            output += `${card.type || '##type/'}\n`;
            output += `##date/ ${card.dateField || ''}\n`;
            output += `Story mapping guide\n`;
            output += `${card.storyMap || 'MS: [Clip/Scene/Scene name/theme/pg/act]'}\n`;
            output += `Clip: ${card.clip || '#1 = 30'}\n`;
            output += `MP3: ${card.mp3 || '#1 = 35'}\n`;
            output += `INT/EXT: ${card.intExtLocation || '[Location] - [DAY/NIGHT]'}\n`;
            output += `IN: ${card.inPoint || '[Character enters/starts with...]'}\n`;
            output += `Beat: ${card.beat1 || '[Action or line]'}\n`;
            output += `Beat: ${card.beat2 || '[Response/reaction]'}\n`;
            output += `TURN: ${card.turn || '[Realization/reversal/escalation]'}\n`;
            output += `OUT: "${card.outPoint || '[Last line or action]'}"\n`;
            output += `EMO: ${card.emo || '[Start emotion] → [End emotion]'}\n`;
            output += `SHOT: ${card.shot || '[Coverage: wide, 2-shot, CU, etc.]'}\n`;
            output += `Sounds: ${card.sounds || '[Ambient noise, background noise, theme]'}\n`;
            output += `Visual Efx: ${card.visualEfx || '[booms/explosions/blood/bullets]'}\n`;
            output += `Sound fxs: ${card.soundFxs || '[booms/ explosions/ blood / bullets]'}\n`;
            output += `MP3: ${card.mp3fx || '[ boom/ bullets/bang/animal/human/ship]'}\n`;
            output += `Syfy: ${card.syfy || '[computers/science/virus/]'}\n`;
            output += `Characters: [${chars.length > 0 ? chars.join(', ') : 'c1, c2, c3, c4'}]\n`;
            output += `Status: [${card.status.toUpperCase()}]\n`;
            
            if (includeAll) {
                if (card.memory) {
                    output += `\nMEMORY:\n${card.memory.replace(/<[^>]*>/g, '')}\n`;
                }
                
                const hasShots = ['A', 'B', 'C', 'D', 'E', 'F'].some(r => card[`shots${r}`].length > 0);
                if (hasShots) {
                    output += `\nSHOT LISTS:\n`;
                    ['A', 'B', 'C', 'D', 'E', 'F'].forEach(roll => {
                        if (card[`shots${roll}`].length > 0) {
                            output += `${roll} Roll:\n`;
                            card[`shots${roll}`].forEach(s => {
                                output += `  Shot ${s.id}: ${s.description} | ${s.lens} | ${s.duration} | ${s.notes}\n`;
                            });
                        }
                    });
                }
                
                if (card.priceRate > 0) {
                    output += `\nQUOTE: Rate $${card.priceRate.toFixed(2)} | Total $${card.priceTotal.toFixed(2)}\n`;
                }
                
                if (card.lineItems.length > 0) {
                    output += `\n────────────────────────────────────────\n`;
                    output += `LINE ITEMS:\n`;
                    card.lineItems.forEach(item => {
                        output += `  ${item.account.padEnd(8)} ${item.description.padEnd(25)} ${item.quantity}x $${item.rate.toFixed(2)} = $${item.total.toFixed(2)}\n`;
                    });
                    const subtotal = card.lineItems.reduce((sum, item) => sum + item.total, 0);
                    output += `────────────────────────────────────────\n`;
                    output += `  Subtotal: $${subtotal.toFixed(2)}\n`;
                    output += `  Tax (8.5%): $${(subtotal * 0.085).toFixed(2)}\n`;
                    output += `  TOTAL: $${(subtotal * 1.085).toFixed(2)}\n`;
                }
            }
            
            return output;
        }

