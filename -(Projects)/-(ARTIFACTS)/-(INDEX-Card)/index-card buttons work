        function validateCard() {
            const errors = [];
            const card = cards[activeCard];
            
            if (!card.sceneTitle.trim()) errors.push('Scene Title is required');
            if (!card.actHeader.trim()) errors.push('Act/Timeline Header is required');
            if (card.actHeader && !/^\d{3}\/\d{3} Act \d+ Pg \d+/.test(card.actHeader)) {
                errors.push('Act Header should follow format: 001/112 Act 1 Pg 05');
            }
            if (!card.intExtLocation.trim()) errors.push('INT/EXT Location is required');
            
            ['inPoint', 'beat1', 'beat2', 'turn', 'outPoint'].forEach(field => {
                if (card[field] && card[field].length > 100) {
                    errors.push(`${field} exceeds 100 character limit`);
                }
            });

            if (errors.length > 0) {
                showToast('Validation Failed', errors.join('; '), true);
                return false;
            }
            showToast('Validation Passed', 'All fields valid');
            return true;
        }

